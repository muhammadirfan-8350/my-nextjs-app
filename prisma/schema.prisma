generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
}

model CampaignData {
  id           String   @id @default(cuid())
  campaignName String
  platform     String
  spend        Float
  impressions  Int
  clicks       Int
  conversions  Int
  cpa          Float
  roas         Float
  date         DateTime
  createdAt    DateTime @default(now())
}

model DashboardMetric {
  id          String   @id @default(cuid())
  date        DateTime @unique
  totalSpend  Float
  conversions Int
  avgCpa      Float
  roas        Float
  createdAt   DateTime @default(now())
}